{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadQuickSlotObservability",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:DescribeAlarms",
        "logs:StartQuery",
        "logs:GetQueryResults",
        "logs:DescribeLogGroups"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DescribeSecretMetadataOnly",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:*:*:secret:quickslot/*",
        "arn:aws:secretsmanager:*:*:secret:quickslot-*",
        "arn:aws:secretsmanager:*:*:secret:smart-parking/*"
      ]
    },
    {
      "Sid": "RunGuardedSsmChecks",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand",
        "ssm:GetCommandInvocation"
      ],
      "Resource": "*"
    },
    {
      "Sid": "InvokeQuickSlotIacRunner",
      "Effect": "Allow",
      "Action": [
        "lambda:InvokeFunction"
      ],
      "Resource": "arn:aws:lambda:*:*:function:quickslot-iac-runner"
    }
  ]
}
